    style.
      .popover {
        display: none;
        position: absolute;
        max-width: 280px;
        z-index: 1000;
      }
    script(src="js/popover.js", type="module", defer)

    //- избегаем FOUC (Flash of Unstyled Content)
    style.
      [v-cloak] {
        display: none !important;
      }

      /* цветные рамки элементов */
      .border-box {
        border: 1px solid var(--bulma-primary);
        border-bottom: none;
      }
      @media screen and (min-width: 769px) {
      .border-box {
        margin-right: -1px;
      }}

      .border-box:last-child {
        border-bottom: 1px solid var(--bulma-primary);
      }
      .border-bottom {
        border-bottom: 1px solid var(--bulma-primary);
      }

      .border-text { border-color: var(--bulma-text); }
      .border-primary { border-color: var(--bulma-primary); }

      /* скрывающаяся подкнопка */
      .hover-button {
        opacity: 0;
        pointer-events: none; /* Кнопку нельзя нажать, пока она невидима */
        transition: opacity 0.2s ease-in-out;
      }
      .button:hover .hover-button {
        opacity: 1;
        pointer-events: auto; /* Возвращаем возможность клика */
      }

      /* не-интерактивные */
      .is-deaf {
        pointer-events: none;
      }

      /* общие цвета для Semantic */
      [data-theme~='semantic'] {
        --bulma-family-primary: 'Lato', sans-serif;
        --bulma-body-size: 16px; /* default is 16 */

        /*
        --bulma-background
        --bulma-border*/

        /* не работает */
        --bulma-navbar-item-background-a: 0.4;

        /* #2185d0 - "выбранный" цвет */
        --bulma-primary-h: 205.714;
        --bulma-primary-s: 84.135%;
        --bulma-primary-l: 81.569%;
      }

      /* специфичные цвета для Semantic Light */
      [data-theme='light semantic'] {}

      /* специфичные цвета для Semantic Dark */
      [data-theme='dark semantic'] {}

      /* custom colors */
      :root {
        --blue: #0077ee;
        --green: #00ee77;
        --yellow: #eede00;
      }

      .is-blue { color: var(--blue); }
      .is-green { color: var(--green); }
      .is-yellow { color: var(--yellow); }

      /* фиксим таблицы */
      .table.is-borderless td,
      .table.is-borderless th {
        border: none;
        padding-top: 0;
        padding-bottom: 0;
        padding-left: 0.25rem;  /* px-1 */
        padding-right: 0.25rem; /* px-1 */
      }


    // components css styles
    include components.pug
