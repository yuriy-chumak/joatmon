    script.
      //- глобальные информационные переменные
      const isMobile = window.matchMedia("(max-width: 768px)").matches;

      //- регистрационный ивент vue компонент
      window.onVueReady = (callback) => {
        if (window.VueApp)
          callback(window.VueApp);
        else
          window.addEventListener('vue-app-ready', (e) => callback(e.detail), { once: true });
      };

      //- спецметод проверки объекта на пустоту
      Object.defineProperty(Object.prototype, 'isEmpty', {
        value: function() {
          // Проверяем, что это действительно простой объект (а не null или массив)
          return Object.keys(this).length === 0 && this.constructor === Object;
        },
        enumerable: false, // Скрывает метод в циклах for...in
        writable: false, // Запрещает переопределение
        configurable: false // Запрещает удаление метода через delete
      });

      //- возвращает объект с индексами, которые совпадают с полем id
      Object.defineProperty(Array.prototype, 'toIdMap', {
        value: function(key = 'id') {
          return this.reduce((acc, item) => {
            acc[item[key]] = item;
            return acc;
          }, {});
        },
        enumerable: false,
        writable: false,
        configurable: false
      });
      Object.defineProperty(Object.prototype, 'filter', {
        value: function(predicate) {
          return Object.entries(this)
            .filter(([key, value]) => predicate(value, key, this))
            .reduce((acc, [key, value]) => {
              acc[key] = value;
              return acc;
            }, {});
        },
        enumerable: false,
        writable: false,
        configurable: false
      });
