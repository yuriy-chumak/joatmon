    script.
      // главная функция переключения темы:
      const SwitchTheme = (savedTheme) => {
        const systemTheme = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        const theme = savedTheme || systemTheme;
        console.log(savedTheme, systemTheme, theme)
        if (theme)
          document.documentElement.setAttribute('data-theme', theme);
      };
      // сразу установим тему еще до загрузки основного документа
      SwitchTheme(sessionStorage.getItem('currentTheme')); // immediately apply saved theme


    //- стили
    link(href="cdn/bulma@1.0.4/bulma.min.css", rel="stylesheet", type="text/css")

    //- шрифты
    link(href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&display=swap", rel="stylesheet" disabled)

    //- icons
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css')
    link(rel='stylesheet' href='https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css')
    

